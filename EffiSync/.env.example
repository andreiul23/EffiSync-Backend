# ──────────────────────────────────────────────
# EffiSync — Unified Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your real .env to git.
# ──────────────────────────────────────────────

# ─── BACKEND ─────────────────────────────────

# PostgreSQL connection string (replace with your Supabase URL)
DATABASE_URL="postgresql://user:password@host:port/dbname?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://user:password@host:port/dbname"

# Gemini AI Key
GOOGLE_GENERATIVE_AI_API_KEY="your_google_ai_key"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# In production GOOGLE_REDIRECT_URI must EXACTLY match an entry in your
# Google OAuth client's authorized redirect URIs (e.g. https://api.your.app/api/auth/google/callback)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# GitHub OAuth (optional — leave empty to disable GitHub login)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# 32+ random chars. Generate with: openssl rand -hex 32
JWT_SECRET="replace_with_a_long_random_secret_at_least_32_chars"

# When "true", outbound emails are suppressed (useful for staging / demos).
SAFE_MODE="true"

# Public URLs used in OAuth redirects, emails, and CORS
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3000"

# Comma-separated allowlist for CORS in production.
# Example: "https://app.effisync.com,https://staging.effisync.com"
ALLOWED_ORIGINS=""

# Server Configuration
PORT=3000
NODE_ENV="development"

# ─── FRONTEND ────────────────────────────────

# Read at build time by Vite. Must point to the deployed backend URL in production.
VITE_API_URL="http://localhost:3000/api"

