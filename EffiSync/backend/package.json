{
  "name": "@effisync/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx --env-file=../.env node_modules/.bin/prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "tsx --env-file=../.env node_modules/.bin/prisma db push",
    "db:studio": "tsx --env-file=../.env node_modules/.bin/prisma studio",
    "lint": "tsc --noEmit",
    "test:e2e": "tsx --env-file=../.env run-tests.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@fastify/cors": "^11.0.1",
    "@prisma/client": "^6.6.0",
    "ai": "^6.0.168",
    "bcrypt": "^6.0.0",
    "fastify": "^5.3.3",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.6",
    "node-cron": "^3.0.3",
    "zod": "^3.24.4",
    "@effisync/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
