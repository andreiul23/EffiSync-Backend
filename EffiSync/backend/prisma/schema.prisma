// ──────────────────────────────────────────────────────────
// EffiSync — Prisma Schema
// ──────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum TaskStatus {
  PENDING
  IN_PROGRESS
  AWAITING_REVIEW
  COMPLETED
  REJECTED
}

enum TaskCategory {
  CLEANING
  SHOPPING
  ADMINISTRATIVE
  PERSONAL_GROWTH
  OTHER
}

enum TaskType {
  INDIVIDUAL
  GROUP
}

enum TransactionType {
  EARNED
  VETO
}

enum GroupType {
  HOUSEHOLD
  FRIEND_GROUP
  WORK_ENVIRONMENT
}

enum ChatRole {
  USER
  AI
}

// ─── Models ─────────────────────────────────────────────

model User {
  id                 String  @id @default(uuid())
  email              String  @unique
  name               String?
  passwordHash       String?
  githubId           String?
  googleRefreshToken String?
  phone              String?
  gender             String?
  occupation         String?
  age                Int?
  pointsBalance      Int     @default(0)

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id])

  assignedTasks      Task[]              @relation("AssignedTo")
  createdTasks       Task[]              @relation("CreatedBy")
  validatedTasks     Task[]              @relation("ValidatedBy")
  pointsTransactions PointsTransaction[]
  availability       Availability[]
  transactions       Transaction[]
  chatMessages       ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([email])
}

model Household {
  id          String    @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  type        GroupType @default(HOUSEHOLD)
  inviteCode  String    @unique

  members User[]
  tasks   Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String       @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  category     TaskCategory @default(OTHER)
  type         TaskType     @default(INDIVIDUAL)
  difficulty   Int          @default(1) // 1-5
  pointsValue  Int
  refusalCount Int          @default(0)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  validatedById String?
  validatedBy   User?   @relation("ValidatedBy", fields: [validatedById], references: [id])

  householdId String
  household   Household @relation(fields: [householdId], references: [id])

  dueDate       DateTime?
  duration      Int? // duration in minutes (used for calendar sync)
  googleEventId String?   // Google Calendar event ID for deduplication

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([householdId])
  @@index([assignedToId])
  @@index([status])
  @@index([googleEventId])
  @@unique([createdById, googleEventId])
}

model Availability {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  isBusy    Boolean  @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([startTime, endTime])
}

model Transaction {
  id     String          @id @default(uuid())
  type   TransactionType
  amount Int

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PointsTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  role      ChatRole
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
